# Copy to .env and fill in your values. All settings are optional; defaults
# work for most cases. `BLWQ_GEE_PROJECT_ID` is required for GEE Initialize().

# Google Cloud project that has the Earth Engine API enabled. Required.
BLWQ_GEE_PROJECT_ID=your-gcp-project-id

# Optional: path to a service-account JSON key. If set, service-account auth
# is used instead of the cached user credentials from `earthengine authenticate`.
# BLWQ_GEE_SERVICE_ACCOUNT_JSON=credentials/ee-service-account.json

# Optional: override the service-account email (else read from the JSON file).
# BLWQ_GEE_SERVICE_ACCOUNT_EMAIL=earth-engine@your-project.iam.gserviceaccount.com

# Pipeline defaults (override per command with flags)
# BLWQ_DEFAULT_DAYS=90
# BLWQ_DEFAULT_CLOUD_PCT=20
# BLWQ_DEFAULT_SCALE_M=10
# BLWQ_DEFAULT_CRS=EPSG:32643
# BLWQ_OUTPUT_DIR=outputs
# BLWQ_LOG_LEVEL=INFO
# BLWQ_LOG_JSON=false
